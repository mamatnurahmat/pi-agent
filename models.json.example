{
  "providers": {
    "deepseek": {
      "apiKey": "$DEEPSEEK_API_KEY",
      "models": [
        {
          "id": "deepseek-chat",
          "name": "DeepSeek V3",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 1000000,
          "maxTokens": 8192,
          "cost": {
            "input": 0.27,
            "output": 1.10,
            "cacheRead": 0.07,
            "cacheWrite": 0.07
          }
        },
        {
          "id": "deepseek-reasoner",
          "name": "DeepSeek R1",
          "reasoning": true,
          "thinkingLevelMap": {
            "off": null
          },
          "input": ["text"],
          "contextWindow": 1000000,
          "maxTokens": 8192,
          "cost": {
            "input": 0.55,
            "output": 2.19,
            "cacheRead": 0.14,
            "cacheWrite": 0.14
          }
        }
      ]
    }
  }
}