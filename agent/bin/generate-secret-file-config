#!/bin/bash

# Script to generate a Kubernetes Secret YAML from a file
# Arguments:
# $1: deployment name (used to infer namespace and construct secret name file-config-{deployment})
# $2: path to the source file (e.g., .env, config.json, appsettings.json)
# $3: (optional) key name inside the secret. Default: basename of the file (e.g., ".env", "config.json")
#
# Flags:
#   -n <namespace>  : skip auto-detection, use given namespace
#
# Examples:
#   generate-secret-file-config plus-be-merchantappauth-manager .env.staging
#   generate-secret-file-config -n production-qoinplus plus-be-merchantappauth-manager .env.staging

NAMESPACE_FLAG=""
POSITIONAL=()
while [ $# -gt 0 ]; do
  case "$1" in
    -n)
      NAMESPACE_FLAG="$2"
      shift 2
      ;;
    *)
      POSITIONAL+=("$1")
      shift
      ;;
  esac
done

DEPLOY="${POSITIONAL[0]}"
FILE_PATH="${POSITIONAL[1]}"
KEY_NAME="${POSITIONAL[2]}"

if [ -z "$DEPLOY" ] || [ -z "$FILE_PATH" ]; then
  echo "Usage: $(basename "$0") [-n <namespace>] <deployment> <file_path> [key_name]"
  echo ""
  echo "Contoh:"
  echo "  $(basename "$0") ngenwal-be-saasclearingasset-module .env.production"
  echo "  $(basename "$0") -n production-qoinplus plus-be-merchantappauth-manager .env.staging"
  echo "  $(basename "$0") ngenwal-be-saasclearingasset-module appsettings.production.json"
  echo "  $(basename "$0") ngenwal-be-saasclearingasset-module config.yml appsettings.production.yml"
  echo ""
  echo "Script akan:"
  echo "  - Mendeteksi namespace dari deployment (kubectl get deploy -A) atau -n <namespace>"
  echo "  - Membuat file-config-{deployment} sebagai nama secret"
  echo "  - Otomatis menyimpan ke file-config-{deployment}_secret.yaml"
  echo "  - Mencari file di:"
  echo "    1. \$FILE_PATH (langsung)"
  echo "    2. ~/gitops/helmfile/rancher/env/{namespace}/{deployment}/configs/\$FILE_PATH"
  echo "    3. ~/gitops/helmfile/rancher/env/{namespace}/configs/\$FILE_PATH"
  exit 1
fi

# ============================================================
# 1. Cari namespace
# ============================================================

# Mapping: prefix deployment → namespace (dari konfigurasi yang ada)
# bash 3.2 compat (macOS) — no associative arrays, use two parallel arrays
PREFIXES=("ngenwal-be-" "ngenwal-" "plus-be-" "pay-be-" "saas-be-" "saas-")
NAMESPACES=("production-ngenwal" "production-ngenwal" "production-qoinplus" "production-payout" "production-saas" "production-saas")

if [ -n "$NAMESPACE_FLAG" ]; then
  # User explicitly provided namespace
  NAMESPACE="$NAMESPACE_FLAG"
  echo "✓ Using namespace: ${NAMESPACE} (dari flag -n)"
else
  # Auto-detect: exact match via kubectl
  NAMESPACE=$(kubectl get deploy -A --no-headers 2>/dev/null | awk -v dep="$DEPLOY" '$2 == dep {print $1; exit}')

  if [ -z "$NAMESPACE" ]; then
    # Fuzzy match: coba cari substring
    NAMESPACE=$(kubectl get deploy -A --no-headers 2>/dev/null | awk -v dep="$DEPLOY" 'index($2, dep) {print $1; exit}')
  fi

  if [ -z "$NAMESPACE" ]; then
    # Infer from deployment name prefix
    for ((i=0; i<${#PREFIXES[@]}; i++)); do
      prefix="${PREFIXES[$i]}"
      if [[ "$DEPLOY" == ${prefix}* ]]; then
        NAMESPACE="${NAMESPACES[$i]}"
        echo "✓ Inferred namespace: ${NAMESPACE} (dari prefix '${prefix}')"
        break
      fi
    done
  fi

  if [ -z "$NAMESPACE" ]; then
    echo "Error: Deployment '${DEPLOY}' tidak ditemukan di cluster."
    echo ""
    echo "Gunakan flag -n <namespace> untuk menentukan namespace secara manual."
    echo ""
    echo "Contoh: $(basename "$0") -n production-qoinplus $DEPLOY $FILE_PATH"
    echo ""
    echo "Namespace yang tersedia di cluster saat ini:"
    kubectl get ns --no-headers -o custom-columns=":metadata.name" 2>/dev/null | grep -v "^kube-\|^cattle-\|^fleet-" | sort
    exit 1
  fi
fi

echo "✓ Namespace untuk '${DEPLOY}': ${NAMESPACE}"

# ============================================================
# 2. Cari file
# ============================================================
SECRET_NAME="file-config-${DEPLOY}"

# Default key name = .env (bisa di-override lewat arg3)
if [ -z "$KEY_NAME" ]; then
  KEY_NAME=".env"
fi

SEARCH_PATHS=(
  "$FILE_PATH"
  "$HOME/gitops/helmfile/rancher/env/${NAMESPACE}/${DEPLOY}/configs/${FILE_PATH}"
  "$HOME/gitops/helmfile/rancher/env/${NAMESPACE}/configs/${FILE_PATH}"
)

SOURCE_FILE=""
for p in "${SEARCH_PATHS[@]}"; do
  if [ -f "$p" ]; then
    SOURCE_FILE="$p"
    echo "✓ File ditemukan: $p"
    break
  fi
done

if [ -z "$SOURCE_FILE" ]; then
  echo ""
  echo "Error: File '${FILE_PATH}' tidak ditemukan."
  echo ""
  echo "Lokasi yang sudah dicari:"
  for p in "${SEARCH_PATHS[@]}"; do
    echo "  - $p"
  done
  echo ""
  echo "Tips: Gunakan path absolut atau relatif yang benar."
  exit 1
fi

# ============================================================
# 3. Encode file ke base64 (tanpa newline wrapping)
# ============================================================
B64=$(base64 -i "$SOURCE_FILE" | tr -d '\n')
echo "✓ File di-encode ke base64 (${#B64} chars)"

# ============================================================
# 4. Generate YAML dan simpan ke file
# ============================================================
OUTPUT_FILE="${SECRET_NAME}_secret.yaml"

# Tentukan direktori output
GITOPS_CONFIGS_DIR="$HOME/gitops/helmfile/rancher/env/${NAMESPACE}/${DEPLOY}/configs"

if [[ "$SOURCE_FILE" == "$GITOPS_CONFIGS_DIR"* ]]; then
  # File dari gitops configs → simpan di direktori yang sama
  OUTPUT_DIR=$(dirname "$SOURCE_FILE")
elif [[ "$SOURCE_FILE" == /tmp/* ]]; then
  # File dari /tmp → simpan di PWD
  OUTPUT_DIR="$PWD"
else
  # File dari path lain → simpan di PWD
  OUTPUT_DIR="$PWD"
fi

OUTPUT_PATH="${OUTPUT_DIR}/${OUTPUT_FILE}"

cat > "$OUTPUT_PATH" <<YAML
apiVersion: v1
data:
  ${KEY_NAME}: ${B64}
kind: Secret
metadata:
  name: ${SECRET_NAME}
  namespace: ${NAMESPACE}
type: Opaque
YAML

echo ""
echo "✓ Secret YAML disimpan ke: ${OUTPUT_PATH}"
echo "  Total: $(wc -c < "$OUTPUT_PATH") bytes"
echo ""

# ============================================================
# 5. Tampilkan preview (max 30 baris)
# ============================================================
TOTAL_LINES=$(wc -l < "$OUTPUT_PATH")
echo "===== Preview (${TOTAL_LINES} lines) ====="
echo ""

if [ "$TOTAL_LINES" -le 30 ]; then
  cat "$OUTPUT_PATH"
else
  head -15 "$OUTPUT_PATH"
  echo "..."
  echo "(... ${TOTAL_LINES} baris, ${#B64} chars base64 ...)"
  echo "..."
  tail -5 "$OUTPUT_PATH"
fi

echo ""
echo "===== Cara apply ke cluster: ====="
echo ""
echo "  kubectl apply -f ${OUTPUT_PATH}"
echo ""
