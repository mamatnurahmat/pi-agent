#!/bin/bash

# Script to match/compare a file from GitHub with a Kubernetes secret
# Arguments:
# $1: Github repo
# $2: Github ref (branch/tag)
# $3: Github file path
# $4: Kubernetes namespace
# $5: Kubernetes secret name
# $6: Kubernetes secret key

if [ "$#" -lt 6 ]; then
  echo "Usage: $(basename "$0") <repo> <ref> <gh_file_path> <namespace> <secret_name> <secret_key>"
  echo "Example: $(basename "$0") saas-be-profile-manager v3.5.1 .env.production production-saas saas-be-profile-manager .env"
  exit 1
fi

REPO="$1"
REF="$2"
GH_FILE="$3"
NAMESPACE="$4"
SECRET_NAME="$5"
SECRET_KEY="$6"

# Dapatkan direktori script saat ini agar bisa memanggil script lainnya
DIR="$(cd "$(dirname "$0")" && pwd)"

echo "Fetching file '$GH_FILE' from GitHub ($REPO@$REF)..."
"$DIR/gh-get-file" "$REPO" "$REF" "$GH_FILE" > /tmp/gh_file_match.txt
if [ $? -ne 0 ]; then
  echo "Failed to fetch file from GitHub."
  exit 1
fi

echo "Fetching secret key '$SECRET_KEY' from Kubernetes ($NAMESPACE/$SECRET_NAME)..."
"$DIR/get-file-secret" "$NAMESPACE" "$SECRET_NAME" "$SECRET_KEY" > /tmp/k8s_secret_match.txt
if [ $? -ne 0 ]; then
  echo "Failed to fetch secret from Kubernetes."
  exit 1
fi

echo ""
echo "=== Perbandingan (Diff) ==="
echo "(-) Kubernetes Secret  |  (+) GitHub File"
echo "--------------------------------------------------------"

# Bandingkan menggunakan diff
diff --color=always -u /tmp/k8s_secret_match.txt /tmp/gh_file_match.txt

# diff exit code: 0 = sama, 1 = beda, >1 = error
DIFF_STATUS=$?

echo "--------------------------------------------------------"
if [ $DIFF_STATUS -eq 0 ]; then
  echo "MATCH! Data di Kubernetes Secret sama persis dengan file di GitHub."
elif [ $DIFF_STATUS -eq 1 ]; then
  echo "Terdapat perbedaan antara Kubernetes Secret dan file di GitHub."
else
  echo "Terjadi error saat melakukan perbandingan."
fi

# Cleanup
rm -f /tmp/gh_file_match.txt /tmp/k8s_secret_match.txt
exit $DIFF_STATUS
