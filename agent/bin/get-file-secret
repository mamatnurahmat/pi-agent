#!/bin/bash

# Script to get and decode a file from a Kubernetes secret
# Arguments:
# $1: namespace
# $2: secret name (if it doesn't start with 'file-config-', it will be prepended automatically)
# $3: (optional) data key name. If provided, fetches only this key.

NAMESPACE="$1"
NAME="$2"
KEY="$3"

if [ -z "$NAMESPACE" ] || [ -z "$NAME" ]; then
  echo "Usage: $(basename "$0") <namespace> <name> [key]"
  echo "Example: $(basename "$0") production-saas saas-be-clientapi-module"
  echo "Example with key: $(basename "$0") production-saas saas-be-clientapi-module config.json"
  exit 1
fi

# Check if name already starts with 'file-config-'
if [[ "$NAME" != file-config-* ]]; then
  SECRET_NAME="file-config-${NAME}"
else
  SECRET_NAME="$NAME"
fi

# Fetch the secret and decode its data contents
if [ -n "$KEY" ]; then
  # If a specific key is provided, decode only that key
  kubectl get secret "$SECRET_NAME" -n "$NAMESPACE" -o go-template='{{index .data "'"$KEY"'" | base64decode}}'
else
  # Otherwise, just list the available keys without decrypting
  echo "Data key yang tersedia di dalam secret '${SECRET_NAME}':"
  kubectl get secret "$SECRET_NAME" -n "$NAMESPACE" -o go-template='{{range $k,$v := .data}}  - {{$k}}{{"\n"}}{{end}}'
  echo ""
  echo "Silakan jalankan ulang dengan format:"
  echo "  $(basename "$0") $NAMESPACE $NAME <nama-key>"
fi
