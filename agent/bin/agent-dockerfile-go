#!/usr/bin/env python3
"""agent-dockerfile-go: Generate Dockerfile untuk Go project via OpenRouter.

Uses template dari ~/.pi/template/go/Dockerfile dan menyesuaikan
dengan project context (go.mod, cicd.json, entry point).
"""

import json
import os
import sys
import urllib.request
import urllib.error

API_URL = "https://openrouter.ai/api/v1/chat/completions"
TEMPLATE_PATH = os.path.expanduser("~/.pi/template/go/Dockerfile")


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def get_api_key():
    key = os.environ.get("OPENROUTER_API_KEY") or os.environ.get("API_KEY")
    if not key:
        print("❌ Error: OPENROUTER_API_KEY belum di-set.")
        print("   export OPENROUTER_API_KEY=\"sk-or-v1-...\"")
        sys.exit(1)
    return key


def get_model():
    return os.environ.get("MODEL") or "deepseek/deepseek-v4-flash"


def call_llm(system_prompt, user_prompt, api_key, model, max_tokens=4096):
    payload = json.dumps({
        "model": model,
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_prompt},
        ],
        "temperature": 0.1,
        "max_tokens": max_tokens,
    }).encode()

    req = urllib.request.Request(
        API_URL,
        data=payload,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
        },
    )

    try:
        with urllib.request.urlopen(req, timeout=120) as resp:
            data = json.loads(resp.read())
    except urllib.error.HTTPError as e:
        print(f"❌ HTTP {e.code}: {e.reason}")
        print(f"   {e.read().decode()}")
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"❌ Network error: {e.reason}")
        sys.exit(1)

    text = data["choices"][0]["message"]["content"]
    for fence in ("```dockerfile", "```docker", "```"):
        text = text.replace(fence, "")
    return text.strip()


def read_or(path, fallback=""):
    try:
        with open(path) as f:
            return f.read()
    except (FileNotFoundError, IsADirectoryError):
        return fallback


def detect_entry_point():
    """Cari main entry file Go — prioritaskan server.go, lalu main.go,
    lalu file .go pertama yang berisi `func main()`."""
    for candidate in ("server.go", "main.go", "cmd/main.go", "cmd/server.go"):
        if os.path.exists(candidate):
            return candidate
    # fallback: scan *.go for func main
    try:
        for f in sorted(os.listdir(".")):
            if f.endswith(".go") and "func main()" in read_or(f):
                return f
    except (FileNotFoundError, NotADirectoryError):
        pass
    return "server.go"


def detect_go_version():
    mod = read_or("go.mod")
    for line in mod.splitlines():
        if line.startswith("go "):
            return line.strip()
    return "go 1.24"


# ---------------------------------------------------------------------------
# System prompt
# ---------------------------------------------------------------------------

SYSTEM_PROMPT = (
    "Anda adalah DevOps Agent. Tugas Anda adalah membuat Dockerfile untuk project Go "
    "berdasarkan template yang diberikan.\n\n"
    "Aturan:\n"
    "1. Gunakan template sebagai dasar, sesuaikan untuk project spesifik.\n"
    "2. Deteksi Go version dari go.mod dan gunakan image golang yang sesuai.\n"
    "3. Cari entry point file (server.go / main.go) untuk `go build`.\n"
    "4. Gunakan PORT, PROJECT, IMAGE dari cicd.json jika tersedia.\n"
    "5. Optimalkan multi-stage build (builder stage + alpine runtime stage).\n"
    "6. Pertahankan BuildKit secrets untuk private repo dependencies.\n"
    "7. Jika project menggunakan modul private github.com/Qoin-Digital-Indonesia, "
    "pastikan GOPRIVATE, GONOSUMDB, GONOPROXY sudah diatur.\n"
    "8. Output HANYA kode Dockerfile — tanpa penjelasan, tanpa backticks.\n"
    "9. Jangan hapus baris atau fitur penting dari template.\n"
    "10. Sesuaikan LABEL maintainer jika ada informasi author."
)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    api_key = get_api_key()
    model = get_model()

    # --- Read template ---
    if not os.path.exists(TEMPLATE_PATH):
        print(f"❌ Template tidak ditemukan: {TEMPLATE_PATH}")
        sys.exit(1)
    with open(TEMPLATE_PATH) as f:
        template = f.read()

    # --- Read project context ---
    go_mod = read_or("go.mod", "(tidak ditemukan)")
    cicd = read_or("cicd/cicd.json", "{}")
    entry = detect_entry_point()
    go_ver = detect_go_version()
    project_name = os.path.basename(os.getcwd())

    try:
        cicd_obj = json.loads(cicd) if cicd != "{}" else {}
    except json.JSONDecodeError:
        cicd_obj = {}

    port = cicd_obj.get("PORT", "")
    proj = cicd_obj.get("PROJECT") or cicd_obj.get("IMAGE", project_name)

    print(f"🤖 Model: {model}")
    print(f"📦 Project: {proj} (entry: {entry}, {go_ver})")

    user_context = (
        f"=== TEMPLATE DOCKERFILE ===\n{template}\n\n"
        f"=== PROJECT INFO ===\n"
        f"Project name: {proj}\n"
        f"Entry point: {entry}\n"
        f"Go version: {go_ver}\n"
        f"Port: {port}\n\n"
        f"=== GO.MOD ===\n{go_mod}\n\n"
        f"=== CICD.JSON ===\n{cicd}"
    )

    print("⏳ [Dockerfile] Generating...", end=" ", flush=True)
    hasil = call_llm(SYSTEM_PROMPT, user_context, api_key, model, max_tokens=8192)
    print("✅")

    with open("Dockerfile", "w") as f:
        f.write(hasil)

    print("🚀 Dockerfile berhasil digenerate!")
    print("📄 File: Dockerfile")


if __name__ == "__main__":
    main()