#!/usr/bin/env python3
"""
generate-file-config-secrets

Generate K8s Secret YAML `file-config-{app}_secret.yaml` dari folder aplikasi.
Mendeteksi otomatis file konfigurasi (.env.*, .app.config, dll) di dalam:
  1. <app_dir>/deploy/   → semua file di-scan, multi data key
  2. <app_dir>/          → fallback: scan .env.* / .app.config

Usage:
    generate-file-config-secrets [folder_name] [--base-dir <path>] [--namespace <ns>]

Args:
    folder_name     (Opsional) Nama folder aplikasi (contoh: saas-be-loyalty-module).
                    Jika tidak diberikan, proses SEMUA folder di --base-dir.
    --base-dir      Root direktori tempat folder app berada (default: $PWD)
    --namespace     Namespace Kubernetes (auto-detect jika tidak diberikan)
    --out-dir       Direktori output YAML (default: $PWD)
    --dry-run       Tampilkan YAML ke stdout tanpa menulis file
    --report        Path file CSV report (default: tidak membuat report)

Examples:
    generate-file-config-secrets -n production-saas                   # batch semua folder
    generate-file-config-secrets saas-be-loyalty-module               # satu folder
    generate-file-config-secrets saas-be-loyalty-module --base-dir ~/gitops/production-saas
    generate-file-config-secrets saas-be-loyalty-module --namespace production-saas --dry-run
"""

import os
import sys
import base64
import argparse
import subprocess
from pathlib import Path

# ---------------------------------------------------------------------------
# Konfigurasi
# ---------------------------------------------------------------------------
DEPLOY_SUBDIR = "deploy"

# Mapping prefix → namespace (sama seperti bash script generate-secret-file-config)
PREFIX_NAMESPACE_MAP = [
    ("ngenwal-be-", "production-ngenwal"),
    ("ngenwal-",    "production-ngenwal"),
    ("plus-be-",    "production-qoinplus"),
    ("pay-be-",     "production-payout"),
    ("saas-be-",    "production-saas"),
    ("saas-",       "production-saas"),
]

# ---------------------------------------------------------------------------
# Fungsi bantu
# ---------------------------------------------------------------------------

def encode_base64(filepath: str) -> str:
    """Baca file dan kembalikan base64 string satu baris."""
    with open(filepath, "rb") as f:
        return base64.b64encode(f.read()).decode("utf-8")


def detect_namespace(app_name: str) -> str | None:
    """
    Auto-detect namespace dari nama deployment/app:
      1. Cek kubectl get deploy -A (exact match)
      2. Cek kubectl get deploy -A (fuzzy/substring match)
      3. Infer dari prefix name
    """
    # 1) Exact match via kubectl
    try:
        result = subprocess.run(
            ["kubectl", "get", "deploy", "-A", "--no-headers"],
            capture_output=True, text=True, timeout=10
        )
        if result.returncode == 0:
            for line in result.stdout.strip().split("\n"):
                parts = line.split()
                if len(parts) >= 2 and parts[1] == app_name:
                    return parts[0]
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass

    # 2) Fuzzy / substring match
    try:
        result = subprocess.run(
            ["kubectl", "get", "deploy", "-A", "--no-headers"],
            capture_output=True, text=True, timeout=10
        )
        if result.returncode == 0:
            for line in result.stdout.strip().split("\n"):
                parts = line.split()
                if len(parts) >= 2 and app_name in parts[1]:
                    return parts[0]
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass

    # 3) Infer from prefix
    for prefix, ns in PREFIX_NAMESPACE_MAP:
        if app_name.startswith(prefix):
            return ns

    return None


def find_config_files(app_dir: str) -> dict:
    """
    Cari file konfigurasi di folder aplikasi.

    Prioritas:
      1. <app_dir>/deploy/  → semua file di dalamnya
      2. <app_dir>/         → .env.* , app.config , .app.config , *.app.config

    Return: { data_key : filepath_abs }
      - .env.*           → key = ".env"
      - file lainnya     → key = nama file asli
    """
    config_files = {}

    deploy_path = os.path.join(app_dir, DEPLOY_SUBDIR)
    if os.path.isdir(deploy_path):
        for fname in os.listdir(deploy_path):
            fpath = os.path.join(deploy_path, fname)
            if not os.path.isfile(fpath):
                continue
            key = ".env" if fname.startswith(".env") else fname
            config_files[key] = fpath
        return config_files

    # Fallback: scan langsung di folder app
    try:
        entries = os.listdir(app_dir)
    except FileNotFoundError:
        return {}

    for fname in entries:
        fpath = os.path.join(app_dir, fname)
        if not os.path.isfile(fpath):
            continue
        if fname.startswith(".env"):
            config_files[".env"] = fpath
        elif fname.lower() in ("app.config", ".app.config") or fname.lower().endswith(".app.config"):
            config_files[fname] = fpath

    return config_files


def make_secret_yaml(app_name: str, config_files: dict, namespace: str) -> str:
    """Buat konten K8s Secret YAML dengan multi data key."""
    data_lines = []
    for key in sorted(config_files.keys()):
        b64 = encode_base64(config_files[key])
        data_lines.append(f"  {key}: {b64}")

    data_block = "\n".join(data_lines)

    return f"""apiVersion: v1
kind: Secret
metadata:
  annotations: {{}}
  name: file-config-{app_name}
  namespace: {namespace}
type: Opaque
data:
{data_block}
"""


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="Generate K8s Secret YAML dari file konfigurasi di folder aplikasi.",
        usage="generate-file-config-secrets [folder_name] [--base-dir <path>] [--namespace <ns>] [--out-dir <path>] [--dry-run]"
    )
    parser.add_argument(
        "folder",
        nargs="?",
        default=None,
        help="Nama folder aplikasi (contoh: saas-be-loyalty-module). Jika tidak diberikan, proses SEMUA folder di --base-dir."
    )
    parser.add_argument(
        "--base-dir", default=os.getcwd(),
        help="Root direktori tempat folder app berada (default: current directory)"
    )
    parser.add_argument(
        "--namespace", "-n", default=None,
        help="Namespace Kubernetes (auto-detect jika tidak diberikan)"
    )
    parser.add_argument(
        "--out-dir", default=None,
        help="Direktori output untuk file YAML (default: current directory)"
    )
    parser.add_argument(
        "--dry-run", action="store_true",
        help="Tampilkan YAML ke stdout tanpa menulis file"
    )
    parser.add_argument(
        "--report", default=None,
        help="Path file CSV laporan (default: tidak membuat report)"
    )
    args = parser.parse_args()

    base_dir = os.path.abspath(args.base_dir)

    # ------------------------------------------------------------------
    # 0. Tentukan daftar folder yang akan diproses
    # ------------------------------------------------------------------
    if args.folder:
        # Mode single-folder
        folders = [args.folder]
    else:
        # Mode batch: scan semua subfolder di base_dir
        try:
            entries = sorted(os.listdir(base_dir))
        except FileNotFoundError:
            print(f"[✗] GAGAL: Base directory tidak ditemukan: {base_dir}")
            sys.exit(1)

        folders = []
        for entry in entries:
            entry_path = os.path.join(base_dir, entry)
            if not os.path.isdir(entry_path):
                continue
            # Skip file/dir yang jelas bukan folder app (dimulai dengan . atau file-config-)
            if entry.startswith(".") or entry.startswith("file-config-"):
                continue
            folders.append(entry)

        if not folders:
            print(f"[✗] GAGAL: Tidak ada folder aplikasi ditemukan di {base_dir}")
            sys.exit(1)

        print(f"[*] Mode batch   : {len(folders)} folder ditemukan")
        print()

    # ------------------------------------------------------------------
    # Proses setiap folder
    # ------------------------------------------------------------------
    total_ok = 0
    total_skip = 0
    total_fail = 0

    for app_name in folders:
        app_dir = os.path.join(base_dir, app_name)

        # 1. Validasi folder
        if not os.path.isdir(app_dir):
            print(f"[✗] SKIP: Folder '{app_name}' tidak ditemukan")
            total_skip += 1
            continue

        # 2. Namespace
        namespace = args.namespace
        if not namespace:
            namespace = detect_namespace(app_name)
        if not namespace:
            print(f"[✗] GAGAL [{app_name}]: Namespace tidak dapat dideteksi. Gunakan -n <ns>")
            total_fail += 1
            continue

        # 3. Cari file konfigurasi
        config_files = find_config_files(app_dir)

        if not config_files:
            print(f"[✗] SKIP [{app_name}]: Tidak ada file konfigurasi")
            total_skip += 1
            continue

        files_list = ", ".join(sorted(config_files.keys()))

        # 4. Generate YAML
        secret_name = f"file-config-{app_name}"
        yaml_content = make_secret_yaml(app_name, config_files, namespace)
        out_filename = f"{secret_name}_secret.yaml"

        if args.dry_run:
            print(f"\n{'='*50}")
            print(f"[{app_name}] namespace={namespace}  keys={files_list}")
            print(yaml_content, end="")
            print("=" * 50)
        else:
            out_dir = os.path.abspath(args.out_dir or os.getcwd())
            out_path = os.path.join(out_dir, out_filename)
            with open(out_path, "w") as f:
                f.write(yaml_content)
            print(f"[✓] {app_name:45s}  ns={namespace:20s}  keys=[{files_list}]")

        # 5. Report CSV (opsional) — append per folder
        if args.report:
            import csv
            report_path = os.path.abspath(args.report)
            file_exists = os.path.isfile(report_path)
            with open(report_path, "a" if file_exists else "w", newline="") as f:
                writer = csv.DictWriter(f, fieldnames=[
                    "folder", "config_files_found", "secret_file",
                    "secret_name", "namespace", "status"
                ])
                if not file_exists:
                    writer.writeheader()
                writer.writerow({
                    "folder": app_name,
                    "config_files_found": files_list,
                    "secret_file": out_filename,
                    "secret_name": secret_name,
                    "namespace": namespace,
                    "status": "berhasil",
                })

        total_ok += 1

    # ------------------------------------------------------------------
    # Ringkasan akhir
    # ------------------------------------------------------------------
    if len(folders) > 1:
        print(f"\n----- Ringkasan -----")
        print(f"  Total folder : {len(folders)}")
        print(f"  Berhasil     : {total_ok}")
        print(f"  Skip         : {total_skip}")
        print(f"  Gagal        : {total_fail}")
        print(f"---------------------")
        if args.report:
            print(f"[*] Report     : {os.path.abspath(args.report)}")


if __name__ == "__main__":
    main()